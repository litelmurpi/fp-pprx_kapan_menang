# Backend (Laravel) Specific
/backend/.env
/backend/.env.backup
/backend/auth.json
/backend/bootstrap/cache/*
!/backend/bootstrap/cache/.gitignore
/backend/config.cache
/backend/storage/*.key
/backend/storage/framework/cache/data/*
!/backend/storage/framework/cache/data/.gitignore
/backend/storage/framework/sessions/*
!/backend/storage/framework/sessions/.gitignore
/backend/storage/framework/testing/*
!/backend/storage/framework/testing/.gitignore
/backend/storage/framework/views/*
!/backend/storage/framework/views/.gitignore
/backend/storage/logs/*
!/backend/storage/logs/.gitignore
/backend/vendor/

# Database files (Exclude dev db)
/backend/database/*.sqlite
/backend/database/*.sqlite-journal
/backend/database/*.sqlite-shm
/backend/database/*.sqlite-wal

# Frontend (Vite/React) Specific
/frontend/node_modules/
/frontend/dist/
/frontend/dist-ssr/
/frontend/*.local
/frontend/.eslintcache
/frontend/.oxlintrc.json
/frontend/.oxlint_cache

# OS/IDE specific files
.DS_Store
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
/.agents/
/skills-lock.json
